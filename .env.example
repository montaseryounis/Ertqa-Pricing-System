# OpenAI API — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Workflow ID from Agent Builder (starts with wf_)
CHATKIT_WORKFLOW_ID=wf_...

# Clerk — https://clerk.com (API keys section)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase — https://supabase.com (Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Admin email — the user with this email gets admin dashboard access
ADMIN_EMAIL=montaser.production@iertqa.com
