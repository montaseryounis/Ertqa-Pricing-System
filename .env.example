# مفتاح OpenAI API — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Workflow ID من Agent Builder — يبدأ بـ wf_
CHATKIT_WORKFLOW_ID=wf_...

# كلمة السر المشتركة لفريق المبيعات (اختر واحدة قوية)
TEAM_PASSWORD=change-me-to-a-strong-shared-password

# سر توقيع الجلسات (ولّده عبر: openssl rand -base64 32)
AUTH_SECRET=replace-with-32-plus-random-chars
